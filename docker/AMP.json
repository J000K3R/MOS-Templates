{
  "name": "AMP",
  "repo": "cubecoders/ampbase:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": true,
  "extra_parameters": "--restart=unless-stopped -e AMPACCEPTLICENSE=Yes",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/AMP.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/amp.png",
  "category": [ "games" ],
  "project": "https://cubecoders.com/AMP",
  "support": "https://discourse.cubecoders.com/",
  "description": "AMP (Application Management Panel) by CubeCoders is a professional game server management panel. Manage Minecraft, CS:GO, Rust, Terraria, and 50+ other game servers from a modern web interface. Note: Requires an AMP license from CubeCoders (commercial software).",
  "donate": "https://cubecoders.com/AMP",
  "paths": [
    {
      "name": "AMP Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/amp",
      "container": "/home/amp/.ampdata",
      "description": "AMP configuration, instances, and game server files."
    }
  ],
  "ports": [
    {
      "name": "AMP WebUI",
      "protocol": "tcp",
      "host": "8080",
      "container": "8080",
      "description": "AMP main web interface."
    },
    {
      "name": "Game Port Range",
      "protocol": "tcp",
      "host": "25565-25580",
      "container": "25565-25580",
      "description": "Default Minecraft server ports. Adjust based on your game servers."
    },
    {
      "name": "Game Port Range UDP",
      "protocol": "udp",
      "host": "25565-25580",
      "container": "25565-25580",
      "description": "UDP ports for game servers."
    }
  ],
  "variables": [
    {
      "name": "License Key",
      "key": "AMPLICENCE",
      "value": "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX",
      "mask": true,
      "description": "Your AMP license key from CubeCoders. Get one at https://cubecoders.com/AMP"
    },
    {
      "name": "Accept License",
      "key": "AMPACCEPTLICENSE",
      "value": "Yes",
      "mask": false,
      "description": "Must be set to 'Yes' to accept AMP license terms."
    },
    {
      "name": "Username",
      "key": "AMPUSER",
      "value": "admin",
      "mask": false,
      "description": "Default AMP admin username."
    },
    {
      "name": "Password",
      "key": "AMPPASSWORD",
      "value": "",
      "mask": true,
      "description": "Default AMP admin password (min 8 chars, must be set before first start)."
    },
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "Timezone",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
