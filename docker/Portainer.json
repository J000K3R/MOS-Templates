{
  "name": "Portainer",
  "repo": "portainer/portainer-ce:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=always",
  "post_parameters": null,
  "web_ui_url": "https://[IP]:[PORT:9443]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Portainer.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/portainer.png",
  "category": [ "productivity" ],
  "project": "https://www.portainer.io/",
  "support": "https://github.com/portainer/portainer/issues",
  "description": "Portainer Community Edition is a lightweight service delivery platform for containerized applications that can be used to manage Docker, Swarm, Kubernetes and ACI environments. It is designed to be as simple to deploy as it is to use.",
  "donate": "https://www.portainer.io/pricing",
  "paths": [
    {
      "name": "Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/portainer",
      "container": "/data",
      "description": "Portainer data, settings, and persistent configuration."
    },
    {
      "name": "Docker Socket",
      "mode": "rw",
      "host": "/var/run/docker.sock",
      "container": "/var/run/docker.sock",
      "description": "Docker socket for managing local Docker environment. Required for container management."
    }
  ],
  "ports": [
    {
      "name": "WebUI HTTPS",
      "protocol": "tcp",
      "host": "9443",
      "container": "9443",
      "description": "Portainer web interface (HTTPS)."
    },
    {
      "name": "Edge Agent",
      "protocol": "tcp",
      "host": "8000",
      "container": "8000",
      "description": "Edge Agent port for managing remote Docker environments. Optional."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
