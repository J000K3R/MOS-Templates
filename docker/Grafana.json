{
  "name": "grafana",
  "repo": "grafana/grafana:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:3000]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Grafana.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/grafana.png",
  "category": [ "monitoring" ],
  "project": "https://github.com/grafana/grafana",
  "support": "https://github.com/grafana/grafana/issues",
  "description": "Grafana is the open source analytics and monitoring solution for every database. Create, explore, and share beautiful dashboards with your team.",
  "donate": "https://grafana.com/pricing",
  "paths": [
    {
      "name": "Appdata",
      "mode": "rw",
      "host": "/mnt/cache/appdata/grafana",
      "container": "/var/lib/grafana",
      "description": "Grafana configuration, dashboards, and data storage."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "3000",
      "container": "3000",
      "description": "Grafana Web Interface."
    }
  ],
  "variables": [
    {
      "name": "GF_SECURITY_ADMIN_USER",
      "key": "GF_SECURITY_ADMIN_USER",
      "value": "admin",
      "mask": false,
      "description": "Username for the Grafana admin account."
    },
    {
      "name": "GF_SECURITY_ADMIN_PASSWORD",
      "key": "GF_SECURITY_ADMIN_PASSWORD",
      "value": "admin",
      "mask": true,
      "description": "Password for the Grafana admin account (change this!)."
    },
    {
      "name": "GF_USERS_ALLOW_SIGN_UP",
      "key": "GF_USERS_ALLOW_SIGN_UP",
      "value": "false",
      "mask": false,
      "description": "Disable user self-registration."
    },
    {
      "name": "GF_SERVER_ROOT_URL",
      "key": "GF_SERVER_ROOT_URL",
      "value": "http://localhost:3000",
      "mask": false,
      "description": "Public URL for Grafana (change if using reverse proxy)."
    },
    {
      "name": "GF_INSTALL_PLUGINS",
      "key": "GF_INSTALL_PLUGINS",
      "value": "",
      "mask": false,
      "description": "Comma-separated list of plugins to install on startup (optional)."
    },
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
