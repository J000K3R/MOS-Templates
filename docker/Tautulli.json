{
  "name": "Tautulli",
  "repo": "lscr.io/linuxserver/tautulli:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8181]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Tautulli.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/tautulli.png",
  "category": [ "media" ],
  "project": "https://github.com/Tautulli/Tautulli",
  "support": "https://github.com/Tautulli/Tautulli/issues",
  "description": "Tautulli is a Python-based monitoring and tracking tool for Plex Media Server. It provides detailed statistics, real-time activity monitoring, and notifications about your Plex library usage.",
  "donate": "https://tautulli.com/donate.html",
  "paths": [
    {
      "name": "Config",
      "mode": "rw",
      "host": "/mnt/cache/appdata/tautulli",
      "container": "/config",
      "description": "Tautulli configuration, database, and logs."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "8181",
      "container": "8181",
      "description": "Tautulli Web Interface port."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
