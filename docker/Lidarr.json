{
  "name": "Lidarr",
  "repo": "lscr.io/linuxserver/lidarr:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8686]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Lidarr.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/lidarr.png",
  "category": [ "media" ],
  "project": "https://github.com/Lidarr/Lidarr",
  "support": "https://github.com/Lidarr/Lidarr/issues",
  "description": "Lidarr is a music collection manager for Usenet and BitTorrent users. It can monitor multiple RSS feeds for new albums from your favorite artists and will grab, sort and rename them.",
  "donate": "https://opencollective.com/lidarr",
  "paths": [
    {
      "name": "Appdata",
      "mode": "rw",
      "host": "/mnt/cache/appdata/lidarr",
      "container": "/config",
      "description": "Configuration files and database for Lidarr."
    },
    {
      "name": "Music",
      "mode": "rw",
      "host": "/mnt/cache/media/music",
      "container": "/music",
      "description": "Location of your music library."
    },
    {
      "name": "Downloads",
      "mode": "rw",
      "host": "/mnt/cache/downloads",
      "container": "/downloads",
      "description": "Download folder for completed downloads from your download client."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "8686",
      "container": "8686",
      "description": "Web interface port for Lidarr."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "UMASK",
      "key": "UMASK",
      "value": "022",
      "mask": false,
      "description": "File creation mask for new files."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
