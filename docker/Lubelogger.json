{
  "name": "Lubelogger",
  "repo": "ghcr.io/hargata/lubelogger:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Lubelogger.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/lubelogger.png",
  "category": [ "Productivity" ],
  "project": "https://github.com/hargata/lubelogger",
  "support": "https://github.com/hargata/lubelogger/issues",
  "description": "Lubelogger is a self-hosted vehicle maintenance and fuel mileage tracker. Log repairs, maintenance, fuel purchases, and expenses for multiple vehicles. Generate reports, track costs, and keep your vehicle history organized with a clean web interface.",
  "donate": "https://github.com/sponsors/hargata",
  "paths": [
    {
      "name": "App Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/lubelogger",
      "container": "/App/data",
      "description": "Lubelogger configuration, database, and uploaded attachments."
    }
    {
      "name": "Keys",
      "mode": "rw",
      "host": "/mnt/cache/appdata/lubelogger-keys",
      "container": "/root/.aspnet/DataProtection-Keys",
      "description": "ASP.NET data protection keys for session encryption."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "8080",
      "container": "8080",
      "description": "Lubelogger web interface (default port 8080)."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    },
    {
      "name": "Log Level",
      "key": "LUBELOGGER_LOG_LEVEL",
      "value": "Information",
      "mask": false,
      "description": "Logging level (Verbose, Debug, Information, Warning, Error)."
    }
  ],
  "devices": [],
  "gpus": []
}