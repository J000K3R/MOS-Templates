{
  "name": "FreshRSS",
  "repo": "freshrss/freshrss:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/FreshRSS.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/freshrss.png",
  "category": [ "productivity" ],
  "project": "https://freshrss.org/",
  "support": "https://github.com/FreshRSS/FreshRSS/issues",
  "description": "FreshRSS is a self-hosted RSS feed aggregator like Leed or Kriss Feed. It is lightweight, easy to work with, powerful, and customizable.",
  "donate": "https://github.com/sponsors/FreshRSS",
  "paths": [
    {
      "name": "Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/freshrss/data",
      "container": "/var/www/FreshRSS/data",
      "description": "FreshRSS data including user data, articles, and configuration."
    },
    {
      "name": "Extensions",
      "mode": "rw",
      "host": "/mnt/cache/appdata/freshrss/extensions",
      "container": "/var/www/FreshRSS/extensions",
      "description": "FreshRSS extensions directory for custom themes and plugins."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "8080",
      "container": "80",
      "description": "FreshRSS web interface."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    },
    {
      "name": "Cron Min",
      "key": "CRON_MIN",
      "value": "*/20",
      "mask": false,
      "description": "Cron schedule for feed updates. Default: every 20 minutes."
    }
  ],
  "devices": [],
  "gpus": []
}
