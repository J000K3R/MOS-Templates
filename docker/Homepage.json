{
  "name": "Homepage",
  "repo": "ghcr.io/gethomepage/homepage:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:3000]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Homepage.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/homepage.png",
  "category": [ "productivity" ],
  "project": "https://gethomepage.dev/",
  "support": "https://github.com/gethomepage/homepage/issues",
  "description": "Homepage is a modern, fully static, fast, and secure dashboard for your server. It integrates with various services like Docker, Plex, Sonarr, Radarr, and many more to provide a comprehensive overview of your infrastructure.",
  "donate": "https://github.com/sponsors/gethomepage",
  "paths": [
    {
      "name": "Config",
      "mode": "rw",
      "host": "/mnt/cache/appdata/homepage/config",
      "container": "/app/config",
      "description": "Homepage configuration files including bookmarks.yaml, services.yaml, settings.yaml, and widgets.yaml."
    },
    {
      "name": "Docker Socket",
      "mode": "ro",
      "host": "/var/run/docker.sock",
      "container": "/var/run/docker.sock",
      "description": "Docker socket for container monitoring and integration."
    },
    {
      "name": "Icons",
      "mode": "ro",
      "host": "/mnt/cache/appdata/homepage/icons",
      "container": "/app/public/icons",
      "description": "Optional custom icons folder for your services."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "3000",
      "container": "3000",
      "description": "Homepage dashboard web interface."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    },
    {
      "name": "Allowed Hosts",
      "key": "HOMEPAGE_ALLOWED_HOSTS",
      "value": "localhost:3000,127.0.0.1:3000",
      "mask": false,
      "description": "Comma-separated list of allowed hosts for security. Add your domain when using reverse proxy."
    }
  ],
  "devices": [],
  "gpus": []
}
