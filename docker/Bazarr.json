{
  "name": "Bazarr",
  "repo": "lscr.io/linuxserver/bazarr:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:6767]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Bazarr.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/bazarr.png",
  "category": [ "media" ],
  "project": "https://github.com/morpheus65535/bazarr",
  "support": "https://github.com/morpheus65535/bazarr/issues",
  "description": "Bazarr is a companion application to Sonarr and Radarr that manages and downloads subtitles based on your requirements.",
  "donate": "https://www.buymeacoffee.com/morpheus65535",
  "paths": [
    {
      "name": "Appdata",
      "mode": "rw",
      "host": "/mnt/cache/appdata/bazarr",
      "container": "/config",
      "description": "Configuration files and database for Bazarr."
    },
    {
      "name": "Movies",
      "mode": "rw",
      "host": "/mnt/cache/media/movies",
      "container": "/movies",
      "description": "Location of your movie library (must match Radarr path)."
    },
    {
      "name": "TV",
      "mode": "rw",
      "host": "/mnt/cache/media/tv",
      "container": "/tv",
      "description": "Location of your TV show library (must match Sonarr path)."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "6767",
      "container": "6767",
      "description": "Web interface port for Bazarr."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "UMASK",
      "key": "UMASK",
      "value": "022",
      "mask": false,
      "description": "File creation mask for new files."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}
