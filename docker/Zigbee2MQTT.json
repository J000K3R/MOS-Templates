{
  "name": "Zigbee2MQTT",
  "repo": "koenkk/zigbee2mqtt:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Zigbee2MQTT.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/zigbee2mqtt.png",
  "category": [ "network", "smart_home" ],
  "project": "https://www.zigbee2mqtt.io/",
  "support": "https://github.com/Koenkk/zigbee2mqtt/issues",
  "description": "Zigbee to MQTT bridge. Use Zigbee devices without the vendor's gateway. Supports USB and network (TCP) coordinators.",
  "donate": "https://github.com/sponsors/Koenkk",
  "paths": [
    {
      "name": "App Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/zigbee2mqtt",
      "container": "/app/data",
      "description": "Zigbee2MQTT configuration, device database, and state."
    }
  ],
  "ports": [
    {
      "name": "Frontend",
      "protocol": "tcp",
      "host": "8080",
      "container": "8080",
      "description": "Zigbee2MQTT web frontend."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    },
    {
      "name": "MQTT Server",
      "key": "ZIGBEE2MQTT_CONFIG_MQTT_SERVER",
      "value": "mqtt://mosquitto:1883",
      "mask": false,
      "description": "MQTT broker URL (e.g. mqtt://192.168.1.10:1883)."
    },
    {
      "name": "MQTT User",
      "key": "ZIGBEE2MQTT_CONFIG_MQTT_USER",
      "value": "",
      "mask": false,
      "description": "MQTT username for authentication."
    },
    {
      "name": "MQTT Password",
      "key": "ZIGBEE2MQTT_CONFIG_MQTT_PASSWORD",
      "value": "",
      "mask": true,
      "description": "MQTT password for authentication."
    },
    {
      "name": "Serial Port",
      "key": "ZIGBEE2MQTT_CONFIG_SERIAL_PORT",
      "value": "/dev/ttyUSB0",
      "mask": false,
      "description": "USB: /dev/ttyUSB0, /dev/ttyACM0 | TCP: tcp://IP:PORT (e.g. SLZB coordinator)"
    },
    {
      "name": "Adapter Type",
      "key": "ZIGBEE2MQTT_CONFIG_SERIAL_ADAPTER",
      "value": "auto",
      "mask": false,
      "description": "auto, zstack, ember, deconz, ezsp. Use 'ember' for SLZB-MR5U, 'zstack' for SONOFF sticks."
    },
    {
      "name": "Frontend",
      "key": "ZIGBEE2MQTT_CONFIG_FRONTEND_ENABLED",
      "value": "true",
      "mask": false,
      "description": "Enable the Z2M web frontend."
    },
    {
      "name": "Home Assistant",
      "key": "ZIGBEE2MQTT_CONFIG_HOMEASSISTANT_ENABLED",
      "value": "true",
      "mask": false,
      "description": "Enable Home Assistant MQTT discovery."
    },
    {
      "name": "Permit Join",
      "key": "ZIGBEE2MQTT_CONFIG_PERMIT_JOIN",
      "value": "false",
      "mask": false,
      "description": "Allow new devices to join. Set 'true' only when pairing."
    }
  ],
  "devices": [],
  "gpus": []
}
