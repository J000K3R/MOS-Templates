{
  "name": "prowlarr",
  "repo": "lscr.io/linuxserver/prowlarr:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:9696]/",
  "readme_url": "https://j000k3r.github.io/MOS-Templates/docs/Templates/Docker/Prowlarr.html",
  "icon": "https://raw.githubusercontent.com/J000K3R/MOS-Templates/main/icons/prowlarr.png",
  "category": [ "media" ],
  "project": "https://github.com/Prowlarr/Prowlarr",
  "support": "https://github.com/Prowlarr/Prowlarr/issues",
  "description": "Prowlarr is an indexer manager/proxy built on the popular arr .net/reactjs base stack to integrate with your various PVR apps. Prowlarr supports management of both Torrent Trackers and Usenet Indexers.",
  "donate": "https://opencollective.com/prowlarr",
  "paths": [
    {
      "name": "Appdata",
      "mode": "rw",
      "host": "/mnt/cache/appdata/prowlarr",
      "container": "/config",
      "description": "Configuration files and database for Prowlarr."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "9696",
      "container": "9696",
      "description": "Web interface port for Prowlarr."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "UMASK",
      "key": "UMASK",
      "value": "022",
      "mask": false,
      "description": "File creation mask for new files."
    }
  ],
  "devices": [],
  "gpus": []
}